# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Transaction pooler URL — used at runtime by Next.js (port 6543, PgBouncer)
# Found in: Supabase → Project Settings → Database → Connection string → Transaction
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# Direct connection URL — used for migrations & seeding (port 5432, no pooler)
# Found in: Supabase → Project Settings → Database → Connection string → Session
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"

# In development: http://localhost:3000
# In production:  https://your-project.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ─── Supabase client (public — safe to expose) ───────────────────────────────
# Found in: Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# ─── Supabase service role (server-only — never expose to client) ─────────────
# Found in: Supabase → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: resend.com → API Keys
# Leave empty to skip email sending (all notifications silently dropped)
RESEND_API_KEY=""

# ─── Vercel Cron (auto-set by Vercel) ────────────────────────────────────────
# Used to authenticate the daily /api/escalations/check cron job
# Set in Vercel → Project → Settings → Environment Variables
CRON_SECRET="replace-with-a-random-secret"
